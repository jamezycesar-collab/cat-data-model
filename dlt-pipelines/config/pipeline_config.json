 { "notebook": { "path": "/dlt-pipelines/fact_pipelines/dlt_fact_cat_quotes" } },
 { "notebook": { "path": "/dlt-pipelines/fact_pipelines/dlt_fact_cat_customer_records" } }
 ],
 "configuration": {
