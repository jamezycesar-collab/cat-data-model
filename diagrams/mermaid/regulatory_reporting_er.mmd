 submission_status : ENUM
 file_name : STRING
 file_size_bytes : BIGINT
 record_count : BIGINT
 ack_status : ENUM
 ack_timestamp : TIMESTAMP
 }

 class regulatory_report {
 <<entity>>
 +report_id : PK
 submission_id : FK reporting_submission
 event_date : DATE
 cat_event_type : FK ref_cat_event_type
 cat_order_id : STRING
 firm_roe_id : STRING
 report_phase : ENUM
 report_payload : JSON
 created_timestamp : TIMESTAMP
 }

 class regulatory_hold {
 <<entity>>
 +hold_id : PK
 entity_type : STRING
 entity_id : STRING
 regulator_code : FK ref_regulator
 hold_type : ENUM
 hold_reason : STRING
 hold_start_date : DATE
 hold_end_date : DATE
 hold_status : ENUM
 }

 class ref_cat_event_type {
 <<reference taxonomy>>
 +cat_event_code : PK
 event_name : STRING
 event_phase : ENUM
 submission_file_type : ENUM
