 }

 class ref_regulator {
 <<reference>>
 +regulator_code : PK
 regulator_name : STRING
 jurisdiction : ISO3166
 submission_endpoint : STRING
 }

 class ref_cfi_category {
 <<reference>>
 +cfi_code : PK
 cfi_category : STRING
