#!/usr/bin/env bash
# Pre-commit hook that runs the spec validator.
#
# Install with:
#   ln -sf ../../guardrails/pre-commit .git/hooks/pre-commit
#
# This runs every time you `git commit`. If the validator fails, the
# commit is rejected.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Only run if any tracked file under one of the trigger paths is staged.
# Diagrams and DDL are triggers because validate_diagrams checks both.
TRIGGER_PATHS="primary-sources/ reference-data/ ddl/ diagrams/ guardrails/"
NEED_RUN=0
for path in $TRIGGER_PATHS; do
  if git diff --cached --name-only | grep -q "^$path"; then
    NEED_RUN=1
    break
  fi
done

if [ "$NEED_RUN" -eq 0 ]; then
  exit 0
fi

echo "Running spec validator..."
python3 guardrails/validate_event_taxonomy.py
echo "Running no-fabrications check..."
python3 guardrails/validate_no_fabrications.py
echo "Running Python syntax check..."
python3 guardrails/validate_python_syntax.py
echo "Running field-mapping check..."
python3 guardrails/validate_field_specifications.py
echo "Running diagram-lint check..."
python3 guardrails/validate_diagrams.py
